
config system
	option hostname 'ImmortalWrt'
	option timezone 'JST-9'
	option ttylogin '0'
	option log_size '128'
	option urandom_seed '0'
	option zonename 'Asia/Tokyo'
	option log_proto 'udp'
	option conloglevel '8'
	option cronloglevel '7'
	option zram_comp_algo 'lzo'

config timeserver 'ntp'
	list server 'ntp.tencent.com'
	list server 'ntp1.aliyun.com'
	list server 'ntp.ntsc.ac.cn'
	list server 'cn.ntp.org.cn'

config imm_init
	option lang '1'
	option system_chn '1'
	option opkg_mirror 'https://mirrors.vsean.net/openwrt'
	option anon_mount '1'

